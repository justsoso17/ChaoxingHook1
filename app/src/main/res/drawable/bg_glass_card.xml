<?xml version="1.0" encoding="utf-8"?>
<!-- Premium glass card: semi-transparent white with subtle border and shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:left="0dp" android:top="1dp" android:right="0dp" android:bottom="2dp">
        <shape>
            <solid android:color="#0D000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Card body -->
    <item>
        <shape>
            <solid android:color="#CCFFFFFF" />
            <corners android:radius="16dp" />
            <stroke android:width="0.5dp" android:color="#33FFFFFF" />
        </shape>
    </item>
    <!-- Inner highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape>
            <solid android:color="#10FFFFFF" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>
