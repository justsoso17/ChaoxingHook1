<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_apple_gradient" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="110dp"
        android:paddingBottom="48dp"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <!-- ====== 手动定位 ====== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_location_manual"
                android:textSize="13sp"
                android:textColor="#99000000"
                android:paddingLeft="4dp"
                android:paddingBottom="8dp"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_location_modify"
                        android:textSize="16sp"
                        android:textColor="#DD000000" />
                    <Switch
                        android:id="@+id/switch_location_modify"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_latitude"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/latitude"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_latitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_latitude"
                        android:inputType="numberDecimal|numberSigned"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_latitude"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_longitude"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/longitude"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_longitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_longitude"
                        android:inputType="numberDecimal|numberSigned"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_longitude"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_map_pick"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pick_from_map"
                        android:textSize="15sp"
                        android:textColor="#FF007AFF" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== 经纬度爆破 ====== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_location_blast"
                android:textSize="13sp"
                android:textColor="#99000000"
                android:paddingLeft="4dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_auto_calculate"
                        android:textSize="16sp"
                        android:textColor="#DD000000" />
                    <Switch
                        android:id="@+id/switch_auto_calculate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_latitude_blast"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/base_latitude"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_latitude_blast"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_latitude_blast"
                        android:inputType="numberDecimal|numberSigned"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_latitude_blast"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_longitude_blast"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/base_longitude"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_longitude_blast"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_longitude_blast"
                        android:inputType="numberDecimal|numberSigned"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_longitude_blast"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_map_pick_blast"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pick_from_map"
                        android:textSize="15sp"
                        android:textColor="#FF007AFF" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== 身份信息 ====== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="身份信息"
                android:textSize="13sp"
                android:textColor="#99000000"
                android:paddingLeft="4dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_address_modify"
                        android:textSize="16sp"
                        android:textColor="#DD000000" />
                    <Switch
                        android:id="@+id/switch_address_modify"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_address"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/address"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_address"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_address"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_name_modify"
                        android:textSize="16sp"
                        android:textColor="#DD000000" />
                    <Switch
                        android:id="@+id/switch_name_modify"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="@string/name"
                        android:textSize="15sp"
                        android:textColor="#DD000000" />
                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_name"
                        android:textSize="15sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null" />
                    <ImageView
                        android:id="@+id/btn_clear_name"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== 高级 ====== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_advanced"
                android:textSize="13sp"
                android:textColor="#99000000"
                android:paddingLeft="4dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_random_device_flag"
                        android:textSize="16sp"
                        android:textColor="#DD000000" />
                    <Switch
                        android:id="@+id/switch_random_device_flag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== 考试 ====== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_exam"
                android:textSize="13sp"
                android:textColor="#99000000"
                android:paddingLeft="4dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_exam_cheat_bypass"
                            android:textSize="16sp"
                            android:textColor="#DD000000" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_exam_cheat_bypass"
                            android:textSize="12sp"
                            android:textColor="#88000000"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_exam_cheat_bypass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_copy_restriction"
                            android:textSize="16sp"
                            android:textColor="#DD000000" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_copy_restriction"
                            android:textSize="12sp"
                            android:textColor="#88000000"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_copy_restriction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_exam_screenshot_replace"
                            android:textSize="16sp"
                            android:textColor="#DD000000" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_exam_screenshot"
                            android:textSize="12sp"
                            android:textColor="#88000000"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_exam_screenshot_replace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/switch_thumb_tint"
                        android:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View android:layout_height="0.5dp" android:layout_width="match_parent"
                    android:layout_marginLeft="16dp" android:background="#18000000" />

                <LinearLayout
                    android:id="@+id/layout_screenshot_path"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/screenshot_image_path"
                        android:textSize="13sp"
                        android:textColor="#88000000" />
                    <EditText
                        android:id="@+id/et_screenshot_path"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_screenshot_path"
                        android:textSize="14sp"
                        android:textColor="#DD000000"
                        android:textColorHint="#44000000"
                        android:background="@null"
                        android:singleLine="true" />
                    <ImageView
                        android:id="@+id/btn_clear_screenshot_path"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_glass_card"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset"
                    android:textSize="17sp"
                    android:textColor="#FFFF3B30" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tip"
                android:textSize="12sp"
                android:textColor="#66000000"
                android:gravity="center"
                android:paddingTop="20dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:gravity="bottom|center"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_glass_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#DD000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />
    </LinearLayout>

</FrameLayout>
